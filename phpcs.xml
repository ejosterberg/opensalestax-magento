<?xml version="1.0"?>
<ruleset name="opensalestax-magento">
    <description>Magento 2 coding standard for the OpenSalesTax module</description>

    <rule ref="Magento2"/>

    <file>EJOsterberg/OpenSalesTax</file>

    <exclude-pattern>*/Test/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*\.xml$</exclude-pattern>
    <exclude-pattern>*\.xsd$</exclude-pattern>

    <!-- Magento2 sniffs surface warnings on every docblock detail; treat the
         alpha module as "error-only" so we ship a quiet build while iterating. -->
    <arg name="warning-severity" value="0"/>

    <!-- Scan PHP only at the alpha stage. Magento2 has XML sniffs we will
         re-enable once the local Windows regex incompatibility is addressed. -->
    <arg name="extensions" value="php"/>
</ruleset>
