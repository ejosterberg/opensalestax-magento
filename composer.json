{
    "name": "ejosterberg/module-opensalestax",
    "description": "Magento 2 module — destination-based US sales tax via the self-hosted OpenSalesTax engine",
    "type": "magento2-module",
    "license": "Apache-2.0",
    "keywords": ["magento", "magento2", "tax", "sales-tax", "us-tax", "opensalestax"],
    "homepage": "https://github.com/ejosterberg/opensalestax-magento",
    "authors": [
        {
            "name": "Eric Osterberg",
            "email": "ejosterberg@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "magento/framework": "^103.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "bitexpert/phpstan-magento": "^0.31",
        "magento/magento-coding-standard": "^32.0"
    },
    "autoload": {
        "psr-4": {
            "EJOsterberg\\OpenSalesTax\\": "EJOsterberg/OpenSalesTax/"
        },
        "files": [
            "EJOsterberg/OpenSalesTax/registration.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "EJOsterberg\\OpenSalesTax\\Test\\": "EJOsterberg/OpenSalesTax/Test/"
        }
    },
    "scripts": {
        "check": [
            "@test",
            "@stan",
            "@cs",
            "@audit"
        ],
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "phpcs --standard=Magento2 EJOsterberg/",
        "audit": "@composer audit"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "magento/composer-dependency-version-audit-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
